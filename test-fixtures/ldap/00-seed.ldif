# --- Groups (8 total) -------------------------------------------------------

# 1. flat-team — 5 direct user members, no nesting
dn: cn=flat-team,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: flat-team
description: Flat team with 5 direct members
member: uid=john.doe,ou=people,dc=test,dc=local
member: uid=jane.smith,ou=people,dc=test,dc=local
member: uid=erik.larsson,ou=people,dc=test,dc=local
member: uid=fatima.khan,ou=people,dc=test,dc=local
member: uid=george.chen,ou=people,dc=test,dc=local

# 2. empty-group — no members (groupOfNames requires at least one member,
#    so we use a placeholder DN pointing to a non-person entry)
dn: cn=empty-group,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: empty-group
description: Empty group for stale detection
member: cn=empty-group,ou=groups,dc=test,dc=local

# 3. database-experts — leaf of nested chain, 2 users
dn: cn=database-experts,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: database-experts
description: Database team - leaf of nesting chain
member: uid=alice.wong,ou=people,dc=test,dc=local
member: uid=carlos.garcia,ou=people,dc=test,dc=local

# 4. backend-team — contains database-experts + 1 extra user
dn: cn=backend-team,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: backend-team
description: Backend team - contains database-experts
member: cn=database-experts,ou=groups,dc=test,dc=local
member: uid=hannah.fischer,ou=people,dc=test,dc=local

# 5. engineering-all — contains backend-team
dn: cn=engineering-all,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: engineering-all
description: All engineering - contains backend-team
member: cn=backend-team,ou=groups,dc=test,dc=local

# 6. marketing-team — 2 users, one shared with database-experts (diamond)
dn: cn=marketing-team,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: marketing-team
description: Marketing team - shares carlos.garcia with engineering path
member: uid=carlos.garcia,ou=people,dc=test,dc=local
member: uid=diana.ross,ou=people,dc=test,dc=local

# 7. all-staff — diamond: contains engineering-all + marketing-team
dn: cn=all-staff,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: all-staff
description: All staff - diamond pattern root
member: cn=engineering-all,ou=groups,dc=test,dc=local
member: cn=marketing-team,ou=groups,dc=test,dc=local

# 8. single-user-group — 1 user only
dn: cn=single-user-group,ou=groups,dc=test,dc=local
objectClass: groupOfNames
cn: single-user-group
description: Single user for permission isolation
member: uid=ivan.petrov,ou=people,dc=test,dc=local
