# =============================================================================
# whohas Test LDAP Seed Data
# =============================================================================
#
# Structure:
#   dc=test,dc=local
#   ├── ou=people          (15 users)
#   │   ├── 10 normal active users
#   │   ├── 2 disabled users (description: DISABLED)
#   │   ├── 1 special chars user (Müller-Schäfer, Björn)
#   │   ├── 1 user with no email
#   │   └── 1 duplicate display name (same cn as another user)
#   └── ou=groups          (8 groups)
#       ├── flat-team               — 5 direct user members, no nesting
#       ├── empty-group             — 0 members
#       ├── database-experts        — 2 users (leaf of nested chain)
#       ├── backend-team            — contains database-experts + 1 user
#       ├── engineering-all         — contains backend-team
#       ├── marketing-team          — 2 users (one shared with database-experts)
#       ├── all-staff               — contains engineering-all + marketing-team (diamond)
#       └── single-user-group       — 1 user only
#
# Nesting:
#   all-staff
#   ├── engineering-all
#   │   └── backend-team
#   │       └── database-experts
#   │           ├── alice.wong
#   │           └── carlos.garcia    ← also in marketing-team (diamond)
#   └── marketing-team
#       ├── carlos.garcia           ← reachable via two paths
#       └── diana.ross
#
# =============================================================================

# --- Organizational Units ---------------------------------------------------

dn: ou=people,dc=test,dc=local
objectClass: organizationalUnit
ou: people

dn: ou=groups,dc=test,dc=local
objectClass: organizationalUnit
ou: groups

